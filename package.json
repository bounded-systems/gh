{
  "name": "@bounded-systems/gh",
  "version": "0.1.0",
  "description": "GitHub CLI wrapper with policy enforcement, rate-limit gating, and budget audit logging",
  "bounded": {
    "tagline": "GitHub CLI wrapper with policy enforcement, rate-limit gating, and budget audit logging",
    "kind": "door"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/gh.git"
  },
  "homepage": "https://github.com/bounded-systems/gh#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/gh/issues"
  },
  "keywords": [
    "github",
    "gh",
    "cli-wrapper",
    "policy",
    "rate-limit"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bounded-systems/env": "workspace:*",
    "@bounded-systems/proc": "workspace:*",
    "@bounded-systems/policy": "workspace:*",
    "@bounded-systems/github-budget": "workspace:*"
  }
}
