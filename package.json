{
  "name": "@bounded-systems/gh",
  "version": "0.1.1",
  "description": "GitHub CLI wrapper with policy enforcement, rate-limit gating, and budget audit logging",
  "bounded": {
    "tagline": "GitHub CLI wrapper with policy enforcement, rate-limit gating, and budget audit logging",
    "kind": "door",
    "facet": "verb",
    "role": "client",
    "domain": "github"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/gh.git"
  },
  "homepage": "https://github.com/bounded-systems/gh#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/gh/issues"
  },
  "keywords": [
    "github",
    "gh",
    "cli-wrapper",
    "policy",
    "rate-limit",
    "seam"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@bounded-systems/seam-check": "npm:@jsr/bounded-systems__seam-check@^0.1.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bounded-systems/env": "npm:@jsr/bounded-systems__env@^0.2.0",
    "@bounded-systems/github-budget": "npm:@jsr/bounded-systems__github-budget@^0.1.0",
    "@bounded-systems/policy": "npm:@jsr/bounded-systems__policy@^0.2.1",
    "@bounded-systems/proc": "npm:@jsr/bounded-systems__proc@^0.2.3"
  }
}
